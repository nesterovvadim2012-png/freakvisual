package com.example.pvpmod.gui;

import com.example.pvpmod.PvPModClient;
import net.minecraft.client.gui.DrawContext;
import net.minecraft.client.gui.screen.Screen;
import net.minecraft.client.gui.widget.ButtonWidget;
import net.minecraft.text.Text;
import net.minecraft.util.Formatting;

public class PvPModScreen extends Screen {
    
    public PvPModScreen() {
        super(Text.literal("PvP Mod Menu"));
    }
    
    @Override
    protected void init() {
        // Кнопка включения/выключения подсветки
        ButtonWidget highlightButton = ButtonWidget.builder(
            getHighlightButtonText(),
            button -> {
                PvPModClient.HIGHLIGHT_ENABLED = !PvPModClient.HIGHLIGHT_ENABLED;
                button.setMessage(getHighlightButtonText());
            }
        ).dimensions(width / 2 - 100, height / 2 - 20, 200, 20).build();
        
        addDrawableChild(highlightButton);
        
        // Кнопка закрытия
        ButtonWidget closeButton = ButtonWidget.builder(
            Text.literal("Закрыть"),
            button -> close()
        ).dimensions(width / 2 - 100, height / 2 + 20, 200, 20).build();
        
        addDrawableChild(closeButton);
    }
    
    private Text getHighlightButtonText() {
        if (PvPModClient.HIGHLIGHT_ENABLED) {
            return Text.literal("Подсветка игрока: " + Formatting.GREEN + "ВКЛ");
        } else {
            return Text.literal("Подсветка игрока: " + Formatting.RED + "ВЫКЛ");
        }
    }
    
    @Override
    public void render(DrawContext context, int mouseX, int mouseY, float delta) {
        renderBackground(context, mouseX, mouseY, delta);
        context.drawCent TextWithShadow(textRenderer, "PvP Mod", width / 2, height / 2 - 60, 0xFFFFFF);
        super.render(context, mouseX, mouseY, delta);
    }
    
    @Override
    public boolean shouldPause() {
        return false;
    }
}
